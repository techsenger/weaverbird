<?xml version="1.0" encoding="UTF-8" ?>
<Configuration title="Alpha GUI" name="alpha-gui" version="${project.version}" type="base">
    <Repositories>
        <Repository name="local" url="file://${settings.localRepository}"/>
        <Repository name="central" url="${maven.central.url}"/>
    </Repositories>

    <Modules>
        <!--### ASCII TABLE ###-->
        <Module groupId="de.vandermeer" artifactId="asciitable" version="${bom.asciitable.version}"/>
        <Module groupId="de.vandermeer" artifactId="skb-interfaces" version="${bom.skb-interfaces.version}"/>
        <Module groupId="de.vandermeer" artifactId="ascii-utf-themes" version="${ascii.themes.version}"/>
        <Module groupId="org.antlr" artifactId="ST4" version="${bom.st4.version}"/>
        <Module groupId="org.apache.commons" artifactId="commons-lang3" version="${commons.lang.version}"/>

        <!--### TOOLS ###-->
<!--        <Module groupId="org.controlsfx" artifactId="controlsfx" version="11.1.1"/>-->
        <Module groupId="com.techsenger.annotations" artifactId="annotations" version="${bom.annotations.version}"/>
        <Module groupId="com.techsenger.toolkit" artifactId="toolkit-ascii" version="${bom.toolkit.version}"/>
        <Module groupId="com.techsenger.toolkit" artifactId="toolkit-fx" version="${bom.toolkit.version}"/>
        <Module groupId="com.techsenger.toolkit" artifactId="toolkit-http" version="${bom.toolkit.version}"/>
        <Module groupId="com.beust" artifactId="jcommander" version="${bom.jcommander.version}"/>
        <Module groupId="com.google.code.gson" artifactId="gson" version="${bom.gson.version}">
            <!--
                Gson requires reflective access to java.time classes for serialization/deserialization.
                Since java.base is in the boot layer and JPMS does not provide access to the boot layer
                controller, we use a relay approach: java.base opens java.time to the framework core module
                via the add-opens at JVM startup, and the core module relays the access to Gson using
                Module.addOpens().
            -->
            <Directives>
                <Directive type="requestsOpen" layer="alpha-framework:${project.version}" module="java.base" package="java.time"/>
            </Directives>
        </Module>

        <!--### JAVAFX ###-->
        <Module groupId="org.openjfx" artifactId="javafx-base" classifier="${info['javafx.classifier']}" version="${javafx.version}"/>
        <Module groupId="org.openjfx" artifactId="javafx-controls" classifier="${info['javafx.classifier']}" version="${javafx.version}"/>
        <Module groupId="org.openjfx" artifactId="javafx-graphics" classifier="${info['javafx.classifier']}" version="${javafx.version}" nativeAccessEnabled="true"/>
        <Module groupId="org.openjfx" artifactId="javafx-swing" classifier="${info['javafx.classifier']}" version="${javafx.version}"/>
        <Module groupId="org.openjfx" artifactId="jfx-incubator-richtext" classifier="${info['javafx.classifier']}" version="${javafx.version}"/>
        <Module groupId="org.openjfx" artifactId="jfx-incubator-input" classifier="${info['javafx.classifier']}" version="${javafx.version}"/>

        <!--### PATTERNFX ###-->
