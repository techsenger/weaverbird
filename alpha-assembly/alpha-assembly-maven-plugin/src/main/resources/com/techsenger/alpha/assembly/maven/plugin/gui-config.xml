        <Module groupId="com.techsenger.tabshell" artifactId="tabshell-layout" version="${bom.tabshell.version}"/>

        <!--### UML ###-->
        <Module groupId="net.sourceforge.plantuml" artifactId="plantuml-asl" version="${bom.plantuml.version}"/>

