<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3
                              http://maven.apache.org/xsd/assembly-1.1.3.xsd">
    <id>app</id>
    <formats>
        <format>tar</format>
    </formats>
    <baseDirectory>alpha-demo-gui-${project.version}</baseDirectory>
    <includeBaseDirectory>true</includeBaseDirectory>
    <fileSets>
        <fileSet>
            <directory>${project.basedir}/../assembly/bin</directory>
            <fileMode>755</fileMode>
            <filtered>true</filtered>
            <includes>
                <include>standalone.bat</include>
                <include>standalone.sh</include>
            </includes>
            <outputDirectory>bin</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../assembly/config</directory>
            <filtered>true</filtered>
            <includes>
                <include>alpha.csv</include>
                <include>log4j2.xml</include>
            </includes>
            <outputDirectory>config</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../assembly/config/alpha-console-gui</directory>
            <filtered>true</filtered>
            <outputDirectory>config/alpha-console-gui/${project.version}/</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../assembly/config/alpha-executor</directory>
            <filtered>true</filtered>
            <outputDirectory>config/alpha-executor/${project.version}/</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../assembly/config/alpha-repo-maven</directory>
            <filtered>true</filtered>
            <outputDirectory>config/alpha-repo-maven/${project.version}/</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../assembly/config/web-application</directory>
            <filtered>true</filtered>
            <outputDirectory>config/web-application/${project.version}/</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/../assembly/config/web-server</directory>
            <filtered>true</filtered>
            <outputDirectory>config/web-server/${project.version}/</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/assembly/data</directory>
            <filtered>true</filtered>
            <outputDirectory>data</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.build.directory}/dejavu-fonts-ttf-2.37</directory>
            <filtered>false</filtered>
            <outputDirectory>data/alpha-console-gui/${project.version}/dejavu-fonts-ttf-2.37</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.build.directory}/repo</directory>
            <filtered>false</filtered>
            <outputDirectory>repo</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/assembly/script</directory>
            <filtered>true</filtered>
            <outputDirectory>script</outputDirectory>
        </fileSet>
        <fileSet>
            <excludes>
                <exclude>**/*</exclude>
            </excludes>
            <outputDirectory>temp</outputDirectory>
        </fileSet>
    </fileSets>
</assembly>

