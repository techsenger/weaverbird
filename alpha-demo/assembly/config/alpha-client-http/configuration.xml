<?xml version="1.0" encoding="UTF-8" ?>
<Configuration title="Alpha Client HTTP" name="alpha-client-http" version="${project.version}" type="base">
    <Repositories>
        <Repository name="local" url="file://${settings.localRepository}"/>
        <Repository name="central" url="${maven.central.url}"/>
    </Repositories>

    <Modules>
        <!--### TOOLS ###-->
        <Module groupId="com.google.code.gson" artifactId="gson" version="${gson.version}"/>

        <!--### ALPHA ###-->
        <Module groupId="com.techsenger.alpha.net.shared" artifactId="alpha-net-shared-commands" version="${project.version}"/>
        <Module groupId="com.techsenger.alpha.net.shared" artifactId="alpha-net-shared-http" version="${project.version}"/>
        <Module groupId="com.techsenger.alpha.net.client" artifactId="alpha-net-client-commands" version="${project.version}"/>
        <Module groupId="com.techsenger.alpha.net.client" artifactId="alpha-net-client-http" version="${project.version}"/>
    </Modules>
</Configuration>

