<?xml version="1.0" encoding="UTF-8" ?>
<Configuration title="Web Application" name="web-application" version="${project.version}" type="web">
    <Repositories>
        <Repository name="local" url="file://${settings.localRepository}"/>
        <Repository name="central" url="${maven.central.url}"/>
    </Repositories>

    <Modules>
        <!--### TEMPLATE ENGINE ### -->
        <Module groupId="org.thymeleaf" artifactId="thymeleaf" version="3.1.1.RELEASE"/>
        <Module groupId="org.thymeleaf" artifactId="thymeleaf-spring6" version="3.1.1.RELEASE"/>
        <Module groupId="org.attoparser" artifactId="attoparser" version="2.0.6.RELEASE"/>
        <Module groupId="org.unbescape" artifactId="unbescape" version="1.1.6.RELEASE"/>

        <Module groupId="com.techsenger.alpha.demo.web" artifactId="alpha-demo-web-app" version="${project.version}" type="war"/>
    </Modules>
</Configuration>
