<?xml version="1.0" encoding="UTF-8" ?>
<Configuration title="Alpha Console CLI" name="alpha-console-cli" version="${project.version}" type="base">
    <Repositories>
        <Repository name="local" url="file://${settings.localRepository}"/>
        <Repository name="central" url="${maven.central.url}"/>
    </Repositories>

    <Modules>
        <!--### TOOLS ###-->
        <Module groupId="org.jline" artifactId="jline" version="${jline.version}"/>
        <Module groupId="net.java.dev.jna" artifactId="jna" version="${jna.version}"/>

        <!--### ALPHA ###-->
        <Module groupId="com.techsenger.alpha.console" artifactId="alpha-console-commands" version="${project.version}"/>
        <Module groupId="com.techsenger.alpha.console" artifactId="alpha-console-cli" version="${project.version}" active="true"/>
    </Modules>
</Configuration>

